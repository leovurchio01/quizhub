# ============================================================
#  Autenticazione Google — OPZIONALE
# ------------------------------------------------------------
#  Di default l'app è APERTA (nessun login) così funziona
#  offline come PWA sull'iPad. Per richiedere il login Google
#  imposta AUTH_ENABLED=true e compila le tre variabili AUTH_*.
# ============================================================

# Metti "true" solo se vuoi il login Google. Dopo averla cambiata, RIDEPLOIA.
AUTH_ENABLED=false

# Genera con:  openssl rand -base64 32
AUTH_SECRET=

# Da Google Cloud Console (OAuth client ID, tipo "Web application")
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
