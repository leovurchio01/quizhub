# ============================================================
#  QuizHub OS — variabili d'ambiente
# ------------------------------------------------------------
#  Tutto è OPZIONALE: l'app funziona local-first senza nulla.
#  - Login Google (GIS): basta il Client ID pubblico.
#  - AUTH_SECRET: firma il cookie di sessione.
#  - KV_*: sync cloud opzionale (Vercel KV / Upstash).
# ============================================================

# ---------- Login Google — Google Identity Services (opzionale) ----------
# Serve SOLO il Client ID (pubblico) di un "OAuth 2.0 Client ID" tipo
# "Web application" creato nella Google Cloud Console. NESSUN client secret.
#
# Nella configurazione del Client, in "Authorized JavaScript origins" aggiungi:
#   http://localhost:3000         (sviluppo)
#   https://<il-tuo-dominio>      (produzione)
# Non serve alcun "Authorized redirect URI".
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Segreto per firmare il cookie di sessione (HMAC-SHA256).
# Genera con:  openssl rand -base64 32
AUTH_SECRET=

# ---------- Sync cloud (opzionale, zero-knowledge) ----------
# Vercel KV / Upstash Redis (REST). Se assenti, il sync resta disattivato
# e l'app continua a funzionare 100% local-first.
KV_REST_API_URL=
KV_REST_API_TOKEN=
