# ============================================================
#  QuizHub OS — variabili d'ambiente
# ------------------------------------------------------------
#  Tutto è OPZIONALE: l'app funziona local-first senza nulla.
#  - AUTH_*  attiva il login Google (spazi legati all'account + sync).
#  - KV_*    attiva il sync cloud opzionale (Vercel KV / Upstash).
# ============================================================

# ---------- Autenticazione Google (opzionale) ----------
# "true" per richiedere il login Google. Dopo averla cambiata, RIDEPLOIA.
AUTH_ENABLED=false

# Genera con:  openssl rand -base64 32
AUTH_SECRET=

# Da Google Cloud Console (OAuth client ID, tipo "Web application")
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ---------- Sync cloud (opzionale, zero-knowledge) ----------
# Vercel KV / Upstash Redis (REST). Se assenti, il sync resta disattivato
# e l'app continua a funzionare 100% local-first.
KV_REST_API_URL=
KV_REST_API_TOKEN=
